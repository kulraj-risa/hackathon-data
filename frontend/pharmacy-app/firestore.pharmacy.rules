rules_version = '2';
// Rules for the dedicated `pharmacy` Firestore database.
// This database holds ONLY the pharmacy / OncoPA demo collections, fully
// isolated from any other app in the rapids-platform project. No RISA /
// follow-up-tracker collections exist here.
service cloud.firestore {
  match /databases/{database}/documents {
    match /providers/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == docId
        && request.auth.token.email.lower().matches('.*@risalabs[.]ai$');
    }
    match /healthcare_facility/{facilityId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /healthcare_facility_invitation/{docId} {
      allow read: if request.auth != null;
    }
    match /auth_config/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /onco_emr/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /orders/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /medical_pa_orders/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /configurations/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /cmm_workflow/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /cmm_events/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /api_config/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /nycbs_drug/{docId} {
      allow read: if request.auth != null;
    }
    match /nycbs_medical_pa/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /nycbs_claims_pa/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /client/{docId} {
      allow read: if request.auth != null;
      match /{subcollection=**} { allow read: if request.auth != null; }
    }
    match /dashboard_config/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
