{
  "name": "pharmacy-dashboard",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@datadog/browser-rum": "^5.1.0",
    "@datadog/browser-rum-react": "^5.1.0",
    "@octokit/rest": "^22.0.0",
    "@reduxjs/toolkit": "^2.2.4",
    "@uiw/react-json-view": "^2.0.0-alpha.30",
    "axios": "^1.7.8",
    "dotenv": "^16.4.5",
    "env-cmd": "^10.1.0",
    "firebase": "12.1.0",
    "fuse.js": "^7.0.0",
    "immer": "^10.1.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "onchange": "^7.1.0",
    "papaparse": "^5.5.3",
    "pdf-merger-js": "5.1.2",
    "pdfjs-dist": "5.1.91",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view-compare": "^2.0.2",
    "react-medium-image-zoom": "^5.2.14",
    "react-pdf": "9.2.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "6.23.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "risa-data-model": "1.0.154",
    "risa-oasis-ui_v2": "0.5.0",
    "sass": "^1.81.0",
    "typescript": "^4.9.5",
    "uuid": "^11.1.0",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/chrome": "^0.0.268",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^27.5.2",
    "@types/lodash": "^4.17.5",
    "@types/node": "^16.18.98",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-redux": "^7.1.33",
    "@types/redux": "^3.6.0",
    "@types/redux-thunk": "^2.1.0",
    "autoprefixer": "^10.4.19",
    "commitizen": "^4.3.1",
    "concurrently": "^8.2.2",
    "cz-customizable": "^7.4.0",
    "google-auth-library": "^10.6.1",
    "gulp": "^5.0.0",
    "gulp-autoprefixer": "^9.0.0",
    "gulp-concat": "^2.6.1",
    "gulp-flatten": "^0.4.0",
    "gulp-postcss": "^10.0.0",
    "gulp-sass": "^5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.5",
    "prettier": "^3.3.3",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-import-sort": "^0.0.7",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.15"
  },
  "overrides": {
    "react-refresh": "0.14.2"
  },
  "scripts": {
    "bq-proxy": "node cors-proxy.cjs",
    "start": "concurrently -c \"cyan,yellow,green\" \"npm run watch-css\" \"react-scripts start\" \"npm run prettier-watch\"",
    "build": "NODE_NO_WARNINGS=1 npm run build-css && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "build-css": "gulp styles",
    "watch-css": "gulp watch",
    "prettier-watch": "onchange \"**/*\" -- prettier --write --ignore-unknown {{changed}}",
    "start:dev": "env-cmd -f .env.local npm run start",
    "start:prod": "env-cmd -f .env.production npm run start",
    "build:prod": "env-cmd -f .env.production npm run build",
    "build:dev": "env-cmd -f .env.development npm run build",
    "build:demo": "env-cmd -f .env.demo npm run build",
    "build:hackathon": "env-cmd -f .env.hackathon npm run build",
    "build:staging": "env-cmd -f .env.staging npm run build",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting:staging",
    "deploy:demo": "npm run build:demo && firebase deploy --only hosting:demo",
    "deploy:hackathon": "npm run build:hackathon && firebase deploy --only hosting:hackathon",
    "deploy": "node deploy.js",
    "prepare": "husky",
    "gcz": "cz"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 4 chrome version",
      "last 4 firefox version",
      "last 4 safari version"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    },
    "cz-customizable": {
      "config": "./.cz-config.cjs"
    }
  }
}
