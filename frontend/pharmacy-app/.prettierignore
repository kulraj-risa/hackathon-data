# Ignore node_modules
node_modules/

# Ignore build output directories
/dist/
/build/

# Ignore files generated by TypeScript compiler
*.tsbuildinfo

# Ignore configuration files (e.g., TypeScript or Jest config)
*.config.js
*.config.ts
*.rc

# Ignore temporary files
*.log
*.tmp
*.swp
*.swo

# Ignore package manager lock files (useful when auto-formatting lock files isn't necessary)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Ignore compiled JavaScript files
*.js
*.jsx
*.mjs
*.cjs

# Ignore TypeScript declaration files (if you don't want to format them)
*.d.ts

# Ignore certain test or script files
/tests/
/test-utils/
/__mocks__/