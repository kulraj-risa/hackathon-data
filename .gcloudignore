# Controls what `gcloud run deploy --source .` uploads to Cloud Build.
# Keep the upload small and free of PHI / large artifacts.
.git/
venv/
__pycache__/
*.pyc
*.egg-info/
.DS_Store

# Local training data / models may contain clinical text — never upload.
data/
models/

# Confidential internal RISA Notion export + loose source docs — never upload.
Private & Shared/
*.pdf
*.png

# Offline pipelines, tools, scripts, docs — not needed at serve time.
pipelines/
tools/
scripts/
docs/
*.md
!README.md

# Other apps / frontends / vendored platform — separate from the engine build.
frontend/
web/
pharmacy-app/
pharmacy-dashboard-demo/
one-risa-1/
rpa_tools/
boss-plugin/
papers/
extraction/

# Local env
.env
.env.*
